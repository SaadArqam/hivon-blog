# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables (CRITICAL - NEVER COMMIT)
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/

# Logs
*.log

# OS
Thumbs.db

# Documentation files (generated)
*.md
!README.md

# Prevent AI-generated documentation spam
# Only keep essential documentation and README.md

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
/.vercel
.vercel

# Supabase CLI local files and DB
/.supabase
supabase/.db
supabase/.env

# Local development and build caches
/.output
.cache
/.turbo
/.parcel-cache
.vite

# Serverless / deployment artifacts
/.serverless

# Firebase local emulators
/.firebase

# IDE/session specific
*.sublime-workspace
*.sublime-project
.history/

# ESLint cache
.eslintcache

# Optional: local secrets and service keys
# (already ignored above but keep explicit)
.env.local
.env.*.local
*SERVICE_ROLE_KEY*

# Private keys and certificates
*.key
*.crt
*.der
*.p12
*.jks

# Google / GCP
google-credentials.json
service-account*.json

# AWS
.aws/credentials
.aws/config
*.pem

# Docker
.docker
docker-compose.override.yml
docker-compose.*.yml

# Local DB
*.sqlite
*.sqlite3
*.db
db.sqlite

# Editor state
.cache/
.vscode/*
.idea/*

# TLS and certs
certs/
keys/
